# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration  
DATABASE_URL=postgresql://username:password@localhost:5432/agentkeys
DATABASE_MAX_CONNECTIONS=20
DATABASE_IDLE_TIMEOUT=30000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_COMMITMENT=confirmed

# Program IDs
AGENTKEYS_PROGRAM_ID=Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS
BONDING_CURVE_PROGRAM_ID=BondCurveProgramId1111111111111111111111111
TREASURY_PROGRAM_ID=TreasuryProgramId1111111111111111111111111
ACCESS_CONTROL_PROGRAM_ID=AccessControlProgramId1111111111111111111111

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# API Configuration
API_RATE_LIMIT=1000
API_RATE_WINDOW=900000

# WebSocket Configuration
WS_PORT=3002
WS_MAX_CONNECTIONS=1000
WS_HEARTBEAT_INTERVAL=30000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Monitoring
